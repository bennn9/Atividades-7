programa {
  funcao inicio() {
    inteiro comprimento
    // coleta de dados
    escreva("Qual o comprimento da peça? ")
    leia (comprimento)

    se (comprimento < 15)
    escreva("Refugo")
    senao se ((15>=comprimento) e (comprimento<21))
    escreva ("padrão")
    senao 
    escreva("Premiun")


    
  }
}
