programa {
  funcao inicio() {
    inteiro parafuso1, parafuso2
    // declarei a variavel

    escreva("Qual a quantidade de parafusos da Primeira remessa? ")
    leia(parafuso1)
    escreva("Qual a quantidade de parafusos da segunda remessa? ")
    leia(parafuso2)
    // Pedi os dados

    escreva("O estoque total é: ",parafuso1 + parafuso2 )
    
      }
}
