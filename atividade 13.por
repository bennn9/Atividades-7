programa {
  funcao inicio() {
    inteiro a, b
    // coleta de dados 
    escreva("Quanto foi a produção do setor A? ")
    leia (a)
  
    escreva("Quanto foi a produção do setor B? ")
    leia (b)

    se (a > b)
    escreva("O setor A foi oque mais produziou.")
    senao se (b > a)
    escreva("O setor B foi oque mais produziou.")
    senao
    escreva("A produção foi igual para os dois setores.")


    
  }
}
