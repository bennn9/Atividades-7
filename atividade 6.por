programa {
  funcao inicio() {
    // pedir as medidas 
    real largura, comprimento, area 
    
    escreva("Qual o comprimento da peça? ")
    leia(comprimento)

    escreva("Qual a largura da peça?")
    leia(largura)

    // A area vai  ser largura vezes comprimento
    area = largura * comprimento

    // exibir o resultado

    escreva("A área da peça é: ", area)


    
  }
}
